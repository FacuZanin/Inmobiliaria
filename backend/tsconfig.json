{
  "compilerOptions": {
    "types": ["node", "multer", "express"],
    "module": "Node16",
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@modules/*": ["./src/modules/*"],
      "@shared/contracts": ["../shared/dist"],
      "@shared/contracts/*": ["../shared/dist/*"]
    }
  },

  "include": [
    "src/**/*"
  ]
}
